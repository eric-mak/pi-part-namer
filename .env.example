# AI Gateway (already required for /api/parse)
AI_GATEWAY_API_KEY=

# Onshape OAuth — get these from https://dev-portal.onshape.com
# The redirect URI must match exactly what you register in the Developer Portal.
ONSHAPE_CLIENT_ID=
ONSHAPE_CLIENT_SECRET=
ONSHAPE_REDIRECT_URI=https://your-deploy.example.com/api/onshape/callback
